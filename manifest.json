{
  "manifest_version": 3,
  "name": "WordPress Profile Hover Card",
  "version": "1.0.0",
  "description": "Injects a hover card that previews WordPress profiles on {make|developer}.wordpress.org when hovering over profile mention links.",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://make.wordpress.org/*",
        "https://developer.wordpress.org/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://profiles.wordpress.org/*"
  ]
}
